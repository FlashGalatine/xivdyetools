{
  "name": "@xivdyetools/worker-middleware",
  "version": "1.1.0",
  "description": "Shared Hono middleware for xivdyetools Cloudflare Workers (request ID, logger, rate limiting)",
  "author": "XIV Dye Tools",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist coverage",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@xivdyetools/logger": "workspace:*",
    "@xivdyetools/rate-limiter": "workspace:*"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "hono": "^4.12.11",
    "@vitest/coverage-v8": "^4.1.4",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "xivdyetools",
    "middleware",
    "hono",
    "cloudflare-workers",
    "request-id",
    "logger",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/FlashGalatine/xivdyetools.git",
    "directory": "packages/worker-middleware"
  }
}
