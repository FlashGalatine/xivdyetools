{
  "name": "xivdyetools-api-worker",
  "version": "0.5.0",
  "private": true,
  "description": "Public API for XIV Dye Tools - Dye database and color matching",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@xivdyetools/core": "workspace:*",
    "@xivdyetools/types": "workspace:*",
    "@xivdyetools/logger": "workspace:*",
    "@xivdyetools/rate-limiter": "workspace:*",
    "@xivdyetools/worker-middleware": "workspace:*",
    "hono": "^4.12.31",
    "spectral.js": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@xivdyetools/test-utils": "workspace:*",
    "vitest": "^4.1.10",
    "wrangler": "^4.113.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
