{
  "name": "xivdyetools-universalis-proxy",
  "version": "1.4.4",
  "private": true,
  "description": "Cloudflare Worker proxy for Universalis API with CORS support",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": ["xivdyetools", "universalis", "cors", "proxy", "cloudflare-workers"],
  "author": "FlashGalatine",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "vitest": "^4.1.4",
    "wrangler": "^4.82.1"
  },
  "dependencies": {
    "@xivdyetools/rate-limiter": "workspace:*",
    "hono": "^4.12.11"
  }
}
