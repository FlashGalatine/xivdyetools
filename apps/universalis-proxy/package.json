{
  "name": "xivdyetools-universalis-proxy",
  "version": "1.4.5",
  "private": true,
  "description": "Cloudflare Worker proxy for Universalis API with CORS support",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "xivdyetools",
    "universalis",
    "cors",
    "proxy",
    "cloudflare-workers"
  ],
  "author": "FlashGalatine",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "dependencies": {
    "@xivdyetools/rate-limiter": "workspace:*",
    "@xivdyetools/worker-middleware": "workspace:*",
    "hono": "^4.12.28"
  }
}
