{
  "name": "xivdyetools-maintainer",
  "version": "1.0.3",
  "private": true,
  "description": "Developer tool for adding new dyes to xivdyetools-core",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx server/api.ts",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@xivdyetools/core": "workspace:*",
    "vue": "^3.5.40",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/cors": "^2.8.17",
    "@types/node": "^26.1.1",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "vitest": "^4.1.10",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "vite": "^8.1.4",
    "vue-tsc": "^3.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
